property_value: skos:altLabel "model using ordinary differential equation" xsd:string
property_value: skos:altLabel "ODE model" xsd:string
property_value: skos:altLabel "ordinary differential equations model" xsd:string
property_value: skos:definition "model using equations containing a function of one independent variable and its derivatives." xsd:string
property_value: skos:prefLabel "ordinary differential equation model" xsd:string

[Term]
id: MAMO:0000047
is_a: MAMO:0000045
relationship: mamo:hasFeature MAMO:0000064
