ontology: mamo/mamo-full
property_value: owl:versionInfo "2023-02-03" xsd:dateTime
property_value: owl:versionInfo "2026-03-31" xsd:string

[Term]
id: MAMO:0000003
is_a: MAMO:0000037
property_value: seeAlso "http://en.wikipedia.org/wiki/Mathematical_model" xsd:anyURI
property_value: skos:definition "Description of a system using mathematical concepts and language.  The model is composed of a set of variables and a set of equations that establish relationships between the variables. " xsd:string
property_value: skos:example "A set of ordinary differential equation describing a physical process." xsd:string
property_value: skos:prefLabel "mathematical model" xsd:string

[Term]
id: MAMO:0000004
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "http://en.wikipedia.org/wiki/Statistical_model" xsd:anyURI
property_value: skos:definition "Model that describes how one or more random variables are related to one or more random variables." xsd:string
property_value: skos:example "The relationship between the size and the age." xsd:string
property_value: skos:prefLabel "statistical model" xsd:string

[Term]
id: MAMO:0000008
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000056
property_value: seeAlso "http://en.wikipedia.org/wiki/Steady_state_%28chemistry%29" xsd:anyURI
property_value: skos:definition "Model which describes a system where the state variable values do not vary." xsd:string
property_value: skos:prefLabel "steady-state model" xsd:string

[Term]
id: MAMO:0000009
comment: Can be analysed using flux balance analysis [http://identifiers.org/biomodels.kisao/KISAO_0000437].
is_a: MAMO:0000008
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "http://identifiers.org/pubmed/12700248" xsd:anyURI {comment="Reed JL, Palsson BO (2003) Thirteen years of building constraint-based in silico models of Escherichia coli. J Bacteriol, 185(9):2692-9.\n"}
property_value: skos:definition "The constraint-based modeling procedure does not strive to find a single solution but rather finds a collection of all allowable solutions to the governing equations that can be defined (a solution space). The subsequent application of additional constraints further reduces the solution space and, consequently, reduces the number of allowable solutions that a cell can utilize." xsd:string
property_value: skos:prefLabel "constraint-based model" xsd:string

[Term]
id: MAMO:0000010
disjoint_from: MAMO:0000027
property_value: seeAlso "http://en.wikipedia.org/wiki/Variable_%28mathematics%29" xsd:anyURI
property_value: skos:definition "Value that may change within the scope of a given model or set of operations." xsd:string
property_value: skos:prefLabel "variable" xsd:string

[Term]
id: MAMO:0000017
comment: Synonyms: input variable
is_a: MAMO:0000010
disjoint_from: MAMO:0000018
property_value: seeAlso "https://en.wikipedia.org/wiki/Dependent_and_independent_variables;" xsd:anyURI
property_value: seeAlso "https://www.ncsu.edu/labwrite/po/independentvar.htm" xsd:anyURI
property_value: skos:definition "variable which is controlled in an experiment, and that affects other variables during the experiment. An independent variable does not depend on other variables of the model." xsd:string
property_value: skos:prefLabel "independent variable" xsd:string

[Term]
id: MAMO:0000018
comment: Synonyms: output variable
is_a: MAMO:0000010
property_value: seeAlso "https://en.wikipedia.org/wiki/Dependent_and_independent_variables;" xsd:anyURI
property_value: seeAlso "https://www.ncsu.edu/labwrite/po/dependentvar.htm" xsd:anyURI
property_value: skos:definition "variable which is measured in an experiment, and that is affected during the experiment. A dependent variable depends on other variables" xsd:string
property_value: skos:example "Example: in an experiment one controls x and measure y, with a relationship y = ax+b, y is depending on x." xsd:string
property_value: skos:prefLabel "dependent variable" xsd:string

[Term]
id: MAMO:0000019
is_a: MAMO:0000181
disjoint_from: MAMO:0000020
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "https://en.wikipedia.org/wiki/Pharmacokinetics" xsd:anyURI
property_value: skos:altLabel "pharmacokinetics model" xsd:string
property_value: skos:definition "Model dedicated to the determination of the fate of substances administered externally to a living organism. Pharmacokinetics models are divided into several areas including the extent and rate of absorption, distribution, metabolism and excretion (ADME) to which Liberation is sometimes added (LADME)." xsd:string
property_value: skos:prefLabel "pharmacokinetic model" xsd:string

[Term]
id: MAMO:0000020
is_a: MAMO:0000181
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "https://en.wikipedia.org/wiki/Pharmacodynamics" xsd:anyURI
property_value: skos:altLabel "pharmacodynamics model" xsd:string
property_value: skos:definition "Models dedicated to the study of the biochemical and physiological effects of drugs on the body or on microorganisms or parasites within or on the body and the mechanisms of drug action and the relationship between drug concentration and effect." xsd:string
property_value: skos:prefLabel "pharmacodynamic model" xsd:string

[Term]
id: MAMO:0000021
is_a: MAMO:0000180
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "http://en.wikipedia.org/wiki/Multiphysics" xsd:anyURI
property_value: skos:definition "Multiphysics treats simulations that involve multiple physical models or multiple simultaneous physical phenomena. For example, combining chemical kinetics and fluid mechanics or combining finite elements with molecular dynamics. Multiphysics typically involves solving coupled systems of partial differential equations." xsd:string
property_value: skos:prefLabel "multiphysics model" xsd:string

[Term]
id: MAMO:0000022
comment: Rule-based modeling is especially effective in cases where the rule-set is significantly simpler than the model it implies, meaning that the model is a repeated manifestation of a limited number of patterns. 
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "http://en.wikipedia.org/wiki/Rule-based_modeling#For_biochemical_systems" xsd:anyURI
property_value: skos:definition "Model that uses a set of rules used to describe other model instances. The rule-set can be used to create a model, or suitable tools can use a rule-set in place of a model. " xsd:string
property_value: skos:prefLabel "rule-based model" xsd:string

[Term]
id: MAMO:0000023
is_a: MAMO:0000003
property_value: seeAlso "http://en.wikipedia.org/wiki/Computational_model" xsd:anyURI
property_value: skos:definition "mathematical model that requires computer simulations to study the behavior of a complex system. The system under study is often a complex nonlinear system for which simple, intuitive analytical solutions are not readily available. Rather than deriving a mathematical analytical solution to the problem, experimentation with the model is done by adjusting the parameters of the system in the computer, and studying the differences in the outcome of the experiments. " xsd:string
property_value: skos:example "weather forecasting models, earth simulator models, flight simulator models, molecular protein folding models, neural network models." xsd:string
property_value: skos:prefLabel "computational model" xsd:string

[Term]
id: MAMO:0000024
comment: Synonym: multi-agent model
is_a: MAMO:0000023
relationship: mamo:hasFeature MAMO:0000059
relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "http://en.wikipedia.org/wiki/Agent-based_model" xsd:anyURI
property_value: skos:definition "model simulating the actions and interactions of autonomous agents (both individual or collective entities such as organizations or groups) with a view to assessing their effects on the system as a whole" xsd:string
property_value: skos:prefLabel "agent-based model" xsd:string

[Term]
id: MAMO:0000025
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000057
property_value: seeAlso "http://en.wikipedia.org/wiki/Petri_net" xsd:anyURI
property_value: skos:definition "directed bipartite graph, in which the nodes represent transitions (i.e. events that may occur, signified by bars) and places (i.e. conditions, signified by circles). The directed arcs describe which places are pre- and/or postconditions for which transitions (signified by arrows) occurs." xsd:string
property_value: skos:prefLabel "Petri net" xsd:string

[Term]
id: MAMO:0000026
is_a: MAMO:0000180
relationship: mamo:hasFeature MAMO:0000056
property_value: seeAlso "http://en.wikipedia.org/wiki/Computational_neuroscience" xsd:anyURI
property_value: skos:definition "Computational Neuroscience emphasizes descriptions of functional and biologically realistic neurons (and neural systems) and their physiology and dynamics. These models capture the essential features of the biological system at multiple spatial-temporal scales, from membrane currents, protein, and chemical coupling to network oscillations, columnar and topographic architecture, and learning and memory. These computational models are used to frame hypotheses that can be directly tested by current or future biological and/or psychological experiments." xsd:string
property_value: skos:prefLabel "computational Neuroscience model" xsd:string

[Term]
id: MAMO:0000027
property_value: skos:definition "information obtained about a system by the application of an analysis procedure to a model of this system" xsd:string
property_value: skos:example "timecourse of a concentation; EC50" xsd:string
property_value: skos:prefLabel "readout" xsd:string

[Term]
id: MAMO:0000028
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000058
property_value: seeAlso "http://en.wikipedia.org/wiki/Population_models" xsd:anyURI
property_value: skos:definition "type of mathematical model that is applied to the study of population dynamics. " xsd:string
property_value: skos:prefLabel "population model" xsd:string

[Term]
id: MAMO:0000029
is_a: MAMO:0000028
property_value: seeAlso "http://en.wikipedia.org/wiki/Matrix_population_models" xsd:anyURI
property_value: skos:definition "specific type of population model that uses matrix algebra. Matrix algebra, in turn, is simply a form of algebraic shorthand for summarizing a larger number of often repetitious and tedious algebraic computations." xsd:string
property_value: skos:prefLabel "matrix population model" xsd:string

[Term]
id: MAMO:0000030
is_a: MAMO:0000003
property_value: seeAlso "http://en.wikipedia.org/wiki/Algebraic_logic" xsd:anyURI
property_value: skos:altLabel "algebraic logic model" xsd:string
property_value: skos:altLabel "logic model" xsd:string
property_value: skos:definition "model where the discrete values of variables (also called levels) is determined by logical combinations of the values of other variables." xsd:string
property_value: skos:prefLabel "logical model" xsd:string

[Term]
id: MAMO:0000031
is_a: MAMO:0000027
property_value: skos:definition "evolution of a variable value over time" xsd:string
property_value: skos:prefLabel "timecourse" xsd:string

[Term]
id: MAMO:0000032
is_a: MAMO:0000054
property_value: skos:definition "model which take into account the spatial distribution or geometric characteristics of the entities described by its variables." xsd:string
property_value: skos:prefLabel "spatial characteristic" xsd:string

[Term]
id: MAMO:0000033
is_a: MAMO:0000180
relationship: mamo:hasFeature MAMO:0000056
property_value: seeAlso "http://en.wikipedia.org/wiki/Reaction_diffusion_model" xsd:anyURI
property_value: skos:definition "mathematical model which explains how the concentration of one or more substances distributed in space changes under the influence of two processes: local chemical reactions in which the substances are transformed into each other, and diffusion which causes the substances to spread out over a domain in space." xsd:string
property_value: skos:prefLabel "chemical reaction diffusion model" xsd:string

[Term]
id: MAMO:0000034
is_a: MAMO:0000033
property_value: seeAlso "http://en.wikipedia.org/wiki/Finite_Element_Method" xsd:anyURI
property_value: skos:definition "model where the space is split into a number of subspaces (sometimes called voxels) that are each considered homegenous and isotropic." xsd:string
property_value: skos:prefLabel "finite element spatial model" xsd:string

[Term]
id: MAMO:0000035
is_a: MAMO:0000180
property_value: skos:definition "model based on a network of nodes or vertices, linked by edges or arcs. nodes can be physical entities, processes, events or logic operators. Edges can represent fluxs, interactions, influences etc." xsd:string
property_value: skos:prefLabel "network model" xsd:string

[Term]
id: MAMO:0000036
is_a: MAMO:0000035
property_value: seeAlso "http://en.wikipedia.org/wiki/Biochemical_system" xsd:anyURI
property_value: skos:definition "Biochemical network studies chemical processes within and relating to, living organisms." xsd:string
property_value: skos:prefLabel "biochemical network" xsd:string

[Term]
id: MAMO:0000037
property_value: skos:altLabel "model" xsd:string
property_value: skos:definition "Purposeful simplification of reality, designed to imitate certain phenomena or characteristics of a system while downplaying non-essential aspects. Its value lies in the ability to generalise insights from the model to a broader class of systems." xsd:string
property_value: skos:prefLabel "model" xsd:string

[Term]
id: MAMO:0000038
is_a: MAMO:0000036
disjoint_from: MAMO:0000039
property_value: seeAlso "http://identifiers.org/pubmed/19897097" xsd:anyURI {comment="Albert R, Wang R (2009) Discrete dynamic modeling of cellular signaling networks. Methods Enzymol 467:281–306"}
property_value: skos:definition "Signal transduction is a process for cellular communication where the cell receives (and responds to) external stimuli from other cells and from the environment." xsd:string
property_value: skos:prefLabel "signalling network" xsd:string

[Term]
id: MAMO:0000039
is_a: MAMO:0000036
property_value: seeAlso "http://identifiers.org/pubmed/17903290" xsd:anyURI {comment="Schlitt T, Brazma A (2007) Current approaches to gene regulatory network modelling. BMC Bioinf 8(Suppl 6):S9"}
property_value: skos:definition "Gene regulation controls the expression of genes and, consequently, all cellular functions. Gene expression is a process that involves transcription of the gene into mRNA, followed by translation to a protein, which may be subject to post-translational modification. The transcription process is controlled by transcription factors (TFs) that can work as activators or inhibitors. TFs are themselves encoded by genes and subject to regulation, which altogether forms complex regulatory networks." xsd:string
property_value: skos:prefLabel "gene regulatory network" xsd:string

[Term]
id: MAMO:0000040
is_a: MAMO:0000036
property_value: seeAlso "http://identifiers.org/isbn/9780521859035" xsd:anyURI {comment="Palsson B (2006) Systems Biology: Properties of Reconstructed Networks.\nCambridge University Press"}
property_value: skos:definition "Metabolism is a mechanism composed by a set of biochemical reactions, by which the cell sustains its growth and energy requirements. It includes several catabolic and anabolic pathways of enzyme-catalyzed reactions that import substrates from the environment and transform them into energy and building blocks required to build the cellular components. Metabolic pathways are interconnected through intermediate metabolites, forming complex networks." xsd:string
property_value: skos:prefLabel "metabolic network" xsd:string

[Term]
id: MAMO:0000041
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000064
relationship: mamo:isUsedToModel MAMO:0000038
relationship: mamo:isUsedToModel MAMO:0000039
property_value: seeAlso "http://en.wikipedia.org/wiki/Bayesian_network" xsd:anyURI
property_value: skos:altLabel "Bayes model" xsd:string
property_value: skos:altLabel "Bayes network" xsd:string
property_value: skos:altLabel "Bayesian network" xsd:string
property_value: skos:altLabel "belief network" xsd:string
property_value: skos:altLabel "probabilistic DAG model" xsd:string
property_value: skos:altLabel "probabilistic directed acyclic graphical model" xsd:string
property_value: skos:definition "Bayesian networks are a special type of probabilistic graphs. Their nodes represent random variables (discrete or continuous) and the edges represent conditional dependencies, forming a directed acyclic graph. Each node contains a probabilistic function that is dependent on the values of its input nodes." xsd:string
property_value: skos:prefLabel "Bayesian model" xsd:string

[Term]
id: MAMO:0000043
is_a: MAMO:0000041
relationship: mamo:hasFeature MAMO:0000056
property_value: seeAlso "http://identifiers.org/pubmed/15308537" xsd:anyURI {comment="Zou M, Conzen S (2005) A new dynamic Bayesian network (DBN) approach for identifying gene regulatory networks from time course microarray data. Bioinformatics 21(1):71–79"}
property_value: skos:altLabel "dynamic Bayes model" xsd:string
property_value: skos:altLabel "dynamic Bayes network" xsd:string
property_value: skos:altLabel "dynamic Bayesian network" xsd:string
property_value: skos:altLabel "dynamic belief network" xsd:string
property_value: skos:altLabel "dynamic probabilistic DAG model" xsd:string
property_value: skos:altLabel "dynamic probabilistic directed acyclic graphical model" xsd:string
property_value: skos:definition "A dynamic Bayesian network is a Bayesian network that overcomes the inability to model feedback loops. In this case, the variables are replicated for each time step and the feedback is modeled by connecting the nodes at adjacent time steps." xsd:string
property_value: skos:prefLabel "dynamic Bayesian model" xsd:string

[Term]
id: MAMO:0000044
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "http://en.wikipedia.org/wiki/Process_calculus" xsd:anyURI
property_value: skos:altLabel "process calculus" xsd:string
property_value: skos:definition "Process algebras are a family of formal languages for modeling concurrent systems. They generally consist on a set of process primitives, operators for sequential and parallel composition of processes, and communication channels." xsd:string
property_value: skos:prefLabel "process algebra" xsd:string

[Term]
id: MAMO:0000045
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000060
relationship: mamo:isUsedToModel MAMO:0000038
relationship: mamo:isUsedToModel MAMO:0000039
relationship: mamo:isUsedToModel MAMO:0000040
property_value: seeAlso "http://en.wikipedia.org/wiki/Differential_equation" xsd:anyURI
property_value: skos:altLabel "differential equations model" xsd:string
property_value: skos:altLabel "model based on differential equations" xsd:string
property_value: skos:altLabel "model using differential equations" xsd:string
property_value: skos:definition "Differential equations describe the rate of change of continuous variables. They are typically used for modeling dynamical systems in several areas." xsd:string
property_value: skos:prefLabel "differential equation model" xsd:string

[Term]
id: MAMO:0000046
is_a: MAMO:0000045
