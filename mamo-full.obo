relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "https://en.wikipedia.org/wiki/Markov_model" xsd:anyURI
property_value: skos:definition "a stochastic model, that models a process where the state depends on previous states in a non-deterministic way, and assumes the Markov property: the conditional probability distribution of future states of the process (conditional on both past and present values) depends only upon the present state; that is, given the present, the future does not depend on the past." xsd:string
property_value: skos:prefLabel "Markov model" xsd:string

[Term]
id: MAMO:0000194
is_a: MAMO:0000193
property_value: seeAlso "http://en.wikipedia.org/wiki/Hidden_Markov_model" xsd:anyURI
property_value: skos:altLabel "HMM" xsd:string
property_value: skos:definition "a Markov model in which the system being modeled is autonomous and its state is only partially observable. In other words, observations are related to the state of the system, but they are typically insufficient to precisely determine the state." xsd:string
property_value: skos:prefLabel "hidden Markov model" xsd:string

[Term]
id: MAMO:0000195
is_a: MAMO:0000193
property_value: seeAlso "http://en.wikipedia.org/wiki/Markov_chain" xsd:anyURI
property_value: skos:altLabel "discrete-time Markov chain" xsd:string
property_value: skos:altLabel "DTMC" xsd:string
property_value: skos:definition "a Markov model that models the state of a system with a random variable that changes through time. In this context, the Markov property suggests that the distribution for this variable depends only on the distribution of the previous state. The system is autonomous and its state is fully observable." xsd:string
property_value: skos:prefLabel "Markov chain" xsd:string

[Term]
id: MAMO:0000196
is_a: MAMO:0000193
property_value: seeAlso "http://en.wikipedia.org/wiki/Markov_decision_process" xsd:anyURI
property_value: skos:altLabel "MDP" xsd:string
