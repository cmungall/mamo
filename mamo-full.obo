property_value: skos:altLabel "model using partial differential equations" xsd:string
property_value: skos:altLabel "partial differential equations model" xsd:string
property_value: skos:altLabel "PDE model" xsd:string
property_value: skos:definition "model using differential equations that contains unknown multivariable functions and their partial derivatives." xsd:string
property_value: skos:prefLabel "partial differential equation model" xsd:string

[Term]
id: MAMO:0000049
is_a: MAMO:0000003
relationship: mamo:hasFeature MAMO:0000056
relationship: mamo:hasFeature MAMO:0000059
relationship: mamo:hasFeature MAMO:0000064
relationship: mamo:isUsedToModel MAMO:0000038
property_value: seeAlso "http://en.wikipedia.org/wiki/Finite-state_machine" xsd:anyURI
property_value: skos:definition "Interacting state machines are diagram-based formalisms that describe the temporal behavior of a system based on the changes in the states of its parts. They differ from other approaches as they define a system in terms of its states rather than its components." xsd:string
property_value: skos:prefLabel "interacting state machine" xsd:string

[Term]
id: MAMO:0000050
is_a: MAMO:0000023
relationship: mamo:hasFeature MAMO:0000059
relationship: mamo:isUsedToModel MAMO:0000038
relationship: mamo:isUsedToModel MAMO:0000039
relationship: mamo:isUsedToModel MAMO:0000040
property_value: seeAlso "http://en.wikipedia.org/wiki/Cellular_automaton" xsd:anyURI
property_value: skos:definition "Cellular automata are discrete dynamic models that consist on a grid of cells with a finite number of states. A cellular automaton has an initial configuration that changes at each time step through a predefined rule that calculates the state of each cell as a function of the state of its neighbors at the previous step." xsd:string
property_value: skos:prefLabel "cellular automaton" xsd:string

[Term]
id: MAMO:0000051
is_a: MAMO:0000050
relationship: mamo:hasFeature MAMO:0000056
property_value: seeAlso "http://identifiers.org/pubmed/15972011" xsd:anyURI {comment="Wishart DS, Yang R, Arndt D, Tang P, Cruz J (2005) Dynamic cellular automata: an alternative approach to cellular simulation. In Silico Biol., 5(2):139-61."}
property_value: skos:altLabel "DSA" xsd:string
property_value: skos:definition "Dynamic cellular automata are a variation of cellular automata that allows for movement of the cell contents inside the grid, mimicking brownian motion." xsd:string
property_value: skos:prefLabel "dynamic cellular automaton" xsd:string

[Term]
id: MAMO:0000052
is_a: MAMO:0000050
relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "http://en.wikipedia.org/wiki/Stochastic_cellular_automaton" xsd:anyURI
property_value: skos:definition "Cellular automaton whose updating rule is stochastic, which means the new entity's state is not chosen deterministically based on the neighbours' states, but according to some probability distributions depending on the neighbours' states." xsd:string
property_value: skos:prefLabel "stochastic cellular automaton" xsd:string

[Term]
id: MAMO:0000053
is_a: MAMO:0000030
relationship: mamo:isUsedToModel MAMO:0000039
property_value: seeAlso "http://en.wikipedia.org/wiki/Boolean_network" xsd:anyURI
property_value: seeAlso "http://identifiers.org/pubmed/5803332" xsd:anyURI {comment="Kauffman S (1969) Metabolic stability and epigenesis in randomly constructed genetic nets. J Theor Biol 22(3):437–467"}
property_value: skos:definition "Boolean models model networks of genes by boolean variables that represent active and inactive states. At each time step, the state of each gene is determined by a logic rule which is a function of the state of its regulators. The state of all genes forms a global state that changes synchronously." xsd:string
property_value: skos:prefLabel "boolean model" xsd:string

[Term]
id: MAMO:0000054
property_value: skos:altLabel "modeling entity feature" xsd:string
property_value: skos:definition "Dependent entity which another modelling entity has, i.e., that entity exhibits its property. Other common terms for property in natural language are characteristic, property, quality, etc." xsd:string
property_value: skos:prefLabel "modelling entity feature" xsd:string

[Term]
id: MAMO:0000055
is_a: MAMO:0000054
disjoint_from: MAMO:0000058
property_value: seeAlso "http://en.wikipedia.org/wiki/Temporality" xsd:anyURI
property_value: skos:definition "Characterises the evolution of a modelling entity over time." xsd:string
property_value: skos:prefLabel "temporal quality" xsd:string

[Term]
id: MAMO:0000056
is_a: MAMO:0000055
disjoint_from: MAMO:0000057
property_value: seeAlso "http://en.wikipedia.org/wiki/Dynamical" xsd:anyURI
property_value: skos:definition "Characterises a modelling entity that evolves over time." xsd:string
property_value: skos:prefLabel "dynamical characteristic" xsd:string

[Term]
id: MAMO:0000057
is_a: MAMO:0000055
property_value: seeAlso "http://en.wiktionary.org/wiki/static" xsd:anyURI
property_value: skos:definition "Characterises a modelling entity that does not evolve over time." xsd:string
property_value: skos:prefLabel "static characteristic" xsd:string

[Term]
id: MAMO:0000058
is_a: MAMO:0000054
property_value: seeAlso "http://en.wiktionary.org/wiki/qualitative" xsd:anyURI
property_value: seeAlso "http://en.wiktionary.org/wiki/quantitative" xsd:anyURI
property_value: skos:definition "Characterises the possibility to be measured numerically." xsd:string
property_value: skos:prefLabel "quantitative characteristic" xsd:string

[Term]
id: MAMO:0000059
is_a: MAMO:0000058
disjoint_from: MAMO:0000060
property_value: seeAlso "http://en.wiktionary.org/wiki/discrete" xsd:anyURI
property_value: skos:definition "Which values can be enumerated." xsd:string
property_value: skos:prefLabel "discrete characteristic" xsd:string

[Term]
id: MAMO:0000060
is_a: MAMO:0000058
property_value: seeAlso "http://en.wiktionary.org/wiki/continuous" xsd:anyURI
property_value: skos:definition "Which values cannot be enumerated. Whatever two values, there is always another value in between." xsd:string
property_value: skos:prefLabel "continuous characteristic" xsd:string

[Term]
id: MAMO:0000061
is_a: MAMO:0000054
