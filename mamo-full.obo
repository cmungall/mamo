property_value: skos:altLabel "stochastic differential equations model" xsd:string
property_value: skos:definition "model using differential equations in which one or more of the terms is a stochastic process, resulting in a solution which is itself a stochastic process" xsd:string
property_value: skos:prefLabel "stochastic differential equation model" xsd:string

