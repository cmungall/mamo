is_a: MAMO:0000019
property_value: seeAlso "http://en.wikipedia.org/wiki/Physiologically_based_pharmacokinetic_modelling" xsd:anyURI
property_value: seeAlso "http://identifiers.org/pubmed/23945604" xsd:anyURI {comment="HM Jones and K Rowland-Yeo Basic Concepts in Physiologically Based Pharmacokinetic Modeling in Drug Discovery and Development (2013) Pharmacometrics Syst Pharmacol. 2(8): e63."}
property_value: skos:altLabel "PBPK" xsd:string
property_value: skos:definition "A model using a series of differential equations that are parametrized with known physiological variables and represent a quantitative mechanistic framework by which the absorption, distribution, metabolism, and excretion (ADME) of new drugs can be described." xsd:string
property_value: skos:prefLabel "physiologically based pharmacokinetic model" xsd:string

[Term]
id: MAMO:0000204
is_a: MAMO:0000185
property_value: seeAlso "https://en.wikipedia.org/wiki/Square-lattice_Ising_model" xsd:anyURI
property_value: skos:definition "2D Ising model [http://identifiers.org/mamo/MAMO_0000185] of interacting magnetic spins on a square lattice." xsd:string
property_value: skos:prefLabel "square-lattice Ising model" xsd:string

[Term]
id: MAMO:0000205
is_a: MAMO:0000180
property_value: seeAlso "http://identifiers.org/pubmed/22817898" xsd:anyURI {comment="Karr et al. A whole-cell computational model predicts phenotype from genotype. Cell. 2012; 150(2):389-401."}
property_value: skos:definition "Computational model that includes all of the molecular components of a biological cell and their interactions." xsd:string
property_value: skos:prefLabel "whole-cell model" xsd:string

[Term]
id: mamo:MAMO_0000206
is_a: MAMO:0000028
is_a: MAMO:0000180
relationship: mamo:hasFeature MAMO:0000064
property_value: seeAlso "http://identifiers.org/doi/10.1007/978-3-540-78911-6_2" xsd:string {comment="Brauer F. Compartmental Models in Epidemiology. Mathematical Epidemiology. 2008;1945:19-79."}
property_value: seeAlso "https://en.wikipedia.org/wiki/Compartmental_models_in_epidemiology" xsd:string
property_value: skos:definition "Compartmental models simplify the mathematical modelling of infectious diseases. The population is assigned to compartments with labels - for example, S, I, or R, (Susceptible, Infectious, or Recovered). People may progress between compartments. The order of the labels usually shows the flow patterns between the compartments; for example SEIS means susceptible, exposed, infectious, then susceptible again." xsd:string
property_value: skos:prefLabel "epidemiological compartmental model" xsd:string

[Term]
id: mamo:MAMO_0000207
is_a: mamo:MAMO_0000206
disjoint_from: mamo:MAMO_0000208
property_value: seeAlso "http://identifiers.org/doi/10.1007/978-3-540-78911-6_2" xsd:string {comment="Brauer F. Compartmental Models in Epidemiology. Mathematical Epidemiology. 2008;1945:19-79."}
property_value: seeAlso "http://identifiers.org/doi/10.1098/rspa.1927.0118" xsd:string {comment="Kermack, W. O. and McKendrick, A. G. \"A Contribution to the Mathematical Theory of Epidemics.\" Proc. Roy. Soc. Lond. A 115, 700-721, 1927."}
property_value: skos:altLabel "SIR" xsd:string
property_value: skos:altLabel "susceptible-infectious-removed" xsd:string
property_value: skos:altLabel "susceptible-infectious-removed model" xsd:string
property_value: skos:definition "A compartmental epidemiological model with three compartments: susceptible S, infectious I, and removed R. The passage of individuals is modelled from S to I to R." xsd:string
property_value: skos:prefLabel "SIR model" xsd:string

[Term]
id: mamo:MAMO_0000208
is_a: mamo:MAMO_0000206
property_value: seeAlso "http://identifiers.org/doi/10.1007/978-3-540-78911-6_2" xsd:string {comment="Brauer F. Compartmental Models in Epidemiology. Mathematical Epidemiology. 2008;1945:19-79."}
property_value: skos:altLabel "SIS" xsd:string
property_value: skos:altLabel "susceptible-infectious-susceptible" xsd:string
property_value: skos:altLabel "susceptible-infectious-susceptible model" xsd:string
property_value: skos:definition "A compartmental epidemiological model with two compartments: susceptible S and infectious I. The passage of individuals is modelled from S to I and back." xsd:string
property_value: skos:prefLabel "SIS model" xsd:string

[Term]
id: mamo:MAMO_0000209
is_a: mamo:MAMO_0000206
property_value: seeAlso "http://identifiers.org/doi/10.1007/978-3-540-78911-6_2" xsd:string {comment="Brauer F. Compartmental Models in Epidemiology. Mathematical Epidemiology. 2008;1945:19-79."}
property_value: skos:altLabel "SEIR" xsd:string
property_value: skos:altLabel "susceptible-exposed-infectious-recovered" xsd:string
property_value: skos:altLabel "susceptible-exposed-infectious-recovered model" xsd:string
property_value: skos:definition "A compartmental epidemiological model with four compartments: susceptible S, exposed E, infectious I, and removed R. The passage of individuals is modelled from S to E to I to R." xsd:string
property_value: skos:prefLabel "SEIR model" xsd:string

[Term]
id: mamo:MAMO_0000210
is_a: mamo:MAMO_0000206
property_value: seeAlso "http://identifiers.org/doi/10.1007/978-3-540-78911-6_2" xsd:string {comment="Brauer F. Compartmental Models in Epidemiology. Mathematical Epidemiology. 2008;1945:19-79."}
property_value: skos:altLabel "SEIS" xsd:string
property_value: skos:altLabel "susceptible-exposed-infectious-susceptible" xsd:string
property_value: skos:altLabel "susceptible-exposed-infectious-susceptible model" xsd:string
property_value: skos:definition "A compartmental epidemiological model with three compartments: susceptible S, exposed E, and infectious I. The passage of individuals is modelled from S to E to I to S." xsd:string
property_value: skos:prefLabel "SEIS model" xsd:string

[Term]
id: mamo:MAMO_0000211
is_a: MAMO:0000181
property_value: seeAlso "http://identifiers.org/pubmed/11185661" xsd:string {comment="Derendorf H, Lesko LJ, Chaikin P, Colburn WA, Lee P, Miller R, Powell R, Rhodes G, Stanski D, Venitz J. Pharmacokinetic/pharmacodynamic modeling in drug research and development. J Clin Pharmacol. 2000 Dec;40(12 Pt 2):1399-418."}
property_value: skos:altLabel "PK-PD model" xsd:string
property_value: skos:definition "Pharmacokinetic/pharmacodynamic (PK/PD) relationships and modeling builds the bridge between the two classical disciplines of clinical pharmacology: pharmacokinetics and pharmacodynamics. It links the concentration-time profile as assessed by pharmacokinetics to the intensity of observed response as quantified by pharmacodynamics. The resulting so-called integrated PK/PD-models allow the description of the complete time course of the desired and/or undesired effects in response to a drug therapy." xsd:string
property_value: skos:prefLabel "pharmacokinetic-pharmacodynamic model" xsd:string

[Term]
id: mamo:continuous_variable
is_a: MAMO:0000086
property_value: skos:definition "statistical data whose individual element can take any real number value." xsd:string
property_value: skos:prefLabel "continuous data variable" xsd:string

[Term]
id: mamo:ordinal_variable
is_a: MAMO:0000086
property_value: seeAlso "https://en.wikipedia.org/wiki/Ordinal_data" xsd:string
property_value: skos:altLabel "ordinal categorical data variable" xsd:string
property_value: skos:definition "statistical variable whose elements take values that exist on an ordinal scale, i.e. an arbitrary numerical scale where the exact numerical quantity of a particular value has no significance beyond its ability to establish a ranking over a set of data points." xsd:string
property_value: skos:prefLabel "ordinal data variable" xsd:string

